# Ports
SERVER_PORT=3000
CLIENT_PORT=9000
DATABASE_PORT=5432

# Production only: host port for the nginx reverse proxy (static client + API/WebSocket)
PROXY_PORT=8080

# Database
# Docker Compose: use the postgres service name. For pnpm dev on the host, set DATABASE_HOST=localhost.
DATABASE_HOST=postgres
DATABASE_NAME=ux-tweak-chat
DATABASE_USER=uxtweak
DATABASE_PASSWORD=P@ssw0rd

# Server
NODE_ENV=development

CORS_ORIGIN=http://localhost:9000 # Must match CLIENT_PORT — http://localhost:<CLIENT_PORT>
