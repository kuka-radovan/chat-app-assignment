{
  "name": "chat-app-assignment",
  "description": "UXtweak assignment",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "dotenv -e .env -- pnpm --parallel --filter @chat/server --filter @chat/client dev",
    "dev:server": "dotenv -e .env -- pnpm --filter @chat/server dev",
    "dev:client": "dotenv -e .env -- pnpm --filter @chat/client dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "migration:run": "dotenv -e .env -- pnpm --filter @chat/server migration:run",
    "migration:generate": "dotenv -e .env -- pnpm --filter @chat/server migration:generate",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down"
  },
  "author": "Radovan Kuka <kuka.radovan@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "dotenv-cli": "^10.0.0"
  }
}
